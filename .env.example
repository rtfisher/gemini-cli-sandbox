# =============================================================================
# .env.example — copy to .env for LOCAL use (`cp .env.example .env`).
# In a Codespace you normally do NOT need .env: set GEMINI_API_KEY as a
# Codespace secret instead (Settings > Codespaces > Secrets). .env is gitignored.
# Never commit a real key.
# =============================================================================

# --- REQUIRED: your free Gemini API key --------------------------------------
# Get one (no billing / no credit card) at: https://aistudio.google.com/apikey
# Note: some school/Workspace ("education") Google accounts are restricted from
# AI Studio key creation — if yours is blocked, use a personal @gmail.com account.
GEMINI_API_KEY=

# --- Model (default is the current free-tier Flash model) --------------------
# The free key is Flash-tier. gemini-2.5-flash was RETIRED for new users in
# Jul 2026 (returns 404), so the default is now gemini-3.5-flash. Gemini 3 *Pro*
# needs a paid key; Flash models are free. For a deprecation-proof (but less
# reproducible) default you can use the alias gemini-flash-latest.
# This value must match the model pinned in .devcontainer/devcontainer.json
# (containerEnv.GEMINI_MODEL) so every launch path uses the same model.
# NOTE: the model is NOT the only quota lever — the big ones (subagents OFF,
# model routing OFF) live in ~/.gemini/settings.json, generated from
# config/settings.template.json. See README > "Managing the free quota".
GEMINI_MODEL=gemini-3.5-flash

# --- Gemini CLI version (advanced) -------------------------------------------
# 'latest' is fine to start. For a class, pin a specific tested version for
# reproducibility, e.g. GEMINI_CLI_VERSION=0.x.y
GEMINI_CLI_VERSION=latest
